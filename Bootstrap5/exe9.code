<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exercise 9 - Buttons Palette</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container my-5">
        <h2>9. Contextual Button Systems</h2>
        <h4 class="mt-4 text-muted">Exercise 9.1: Context Styles & Outlines</h4>
        <div class="d-flex flex-wrap gap-2 mb-5">
            <button class="btn btn-primary">Primary Action</button>
            <button class="btn btn-secondary">Secondary Option</button>
            <button class="btn btn-success">Success Confirmation</button>
            <button class="btn btn-outline-info">Outline Info System</button>
            <button class="btn btn-outline-danger">Outline Destruction Trigger</button>
        </div>
        <h4 class="text-muted">Exercise 9.2: Button Clusters & Checkbox States</h4>
        <div class="btn-group mb-3" role="group">
            <button type="button" class="btn btn-dark">Left Wing Option</button>
            <button type="button" class="btn btn-dark">Middle Station</button>
            <button type="button" class="btn btn-dark">Right Wing Option</button>
        </div>
        <div class="d-block mt-2">
            <input type="checkbox" class="btn-check" id="toggleState" autocomplete="off">
            <label class="btn btn-outline-primary" for="toggleState">Click to Toggle State Display</label>
        </div>
    </div>
</body>
</html>