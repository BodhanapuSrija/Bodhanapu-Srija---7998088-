<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exercise 13 - Color Systems</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container my-5">
        <h2>13. Context Theme Background Color Layouts</h2>
        <div class="row g-3 my-4">
            <div class="col-md-4">
                <div class="p-4 bg-primary text-white rounded shadow-sm">
                    <h5>Primary Dashboard Node</h5>
                    <p class="mb-0 text-white-50">Operational Metric Safe</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 bg-warning text-dark rounded shadow-sm">
                    <h5>Attention Warning Alert</h5>
                    <p class="mb-0 text-dark-50">System Sync Interrupted</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 bg-danger text-white rounded shadow-sm">
                    <h5>Critical Crash Counter</h5>
                    <p class="mb-0 text-white-50">Emergency Terminations Active</p>
                </div>
            </div>
        </div>
        <h4 class="mt-4 text-muted">Exercise 13.2: High Contrast Linear Gradient Container</h4>
        <div class="p-5 bg-dark bg-gradient text-white rounded shadow border border-secondary">
            <h1 class="display-4 fw-bold text-white">Advanced Data Deep Dive Hub</h1>
            <p class="lead text-light">This panel blends background gradient utilities with dark structural text blocks seamlessly.</p>
        </div>
    </div>
</body>
</html>