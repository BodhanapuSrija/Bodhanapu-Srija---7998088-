<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exercise 6 - Flexbox Utilities</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container my-5">
        <h2>6. Responsive Flexbox Utilities</h2>
        <h4 class="mt-4 text-muted">Exercise 7.1: Flex Orientation Navbar</h4>
        <nav class="d-flex flex-column flex-md-row bg-dark text-white p-3 rounded align-items-center mb-4">
            <div class="fw-bold me-md-auto mb-2 mb-md-0">BRAND BRAND</div>
            <div class="d-flex gap-3">
                <a href="#" class="text-white text-decoration-none">Home</a>
                <a href="#" class="text-white text-decoration-none">Dashboard</a>
            </div>
        </nav>
        <h4 class="text-muted">Exercise 7.2: Space Distribution Card</h4>
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0">Product Core Title</h5>
                    <small class="text-muted">Item Subtitle Details</small>
                </div>
                <span class="badge bg-danger p-2">$49.99</span>
            </div>
        </div>
    </div>
</body>
</html>