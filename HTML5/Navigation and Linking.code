<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">
    <title>Navigation and Linking</title>
    <style>
        body{
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f5f5f5;
        }
        nav{
            background-color: #0d6efd;
            padding: 15px;
            position: sticky;
            top: 0;
        }
        nav a{
            color: white;
            text-decoration: none;
            margin-right: 25px;
            font-size: 18px;
            font-weight: bold;
        }
        section{
            padding: 60px;
            margin: 20px;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
        }
        h2{
            color: #0d6efd;
        }
        .help-link{
            display: inline-block;
            margin-top: 20px;
            background-color: green;
            color: white;
            padding: 12px 20px;
            text-decoration: none;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <!-- Navigation Menu -->
    <nav>
        <a href="#home">Home</a>
        <a href="#events">Events</a>
        <a href="#contact">Contact</a>
        <a href="help.html"
           target="_blank">
              Help
        </a>
    </nav>
    <!-- Home Section -->
    <section id="home">
        <h2>Home Section</h2>
        <p>
            Welcome to the student activity portal.
        </p>
        <p>
            Use the navigation menu to move between sections.
        </p>
    </section>
    <!-- Events Section -->
    <section id="events">
        <h2>Events Section</h2>
        <p>
            Upcoming technical and cultural events are displayed here.
        </p>
        <ul>
            <li>Web Development Workshop</li>
            <li>Hackathon 2026</li>
            <li>Annual Coding Contest</li>
        </ul>
    </section>
    <!-- Contact Section -->
    <section id="contact">
        <h2>Contact Section</h2>
        <p>
            Email: studentportal@gmail.com
        </p>
        <p>
            Phone: +91 9876543210
        </p>
        <a href="help.html"
           target="_blank"
           class="help-link">

           Open Help Document
        </a>
    </section>
</body>
</html>