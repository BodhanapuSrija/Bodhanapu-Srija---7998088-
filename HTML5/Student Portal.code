<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">
    <title>Student Portal</title>
    <style>
        body{
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
        }
        header{
            background-color: #0d6efd;
            color: white;
            padding: 20px;
            text-align: center;
        }
        nav{
            background-color: #212529;
            padding: 15px;
        }
        nav a{
            color: white;
            text-decoration: none;
            margin-right: 20px;
            font-weight: bold;
        }
        main{
            padding: 40px;
            min-height: 300px;
            background-color: white;
        }
        footer{
            background-color: #212529;
            color: white;
            text-align: center;
            padding: 15px;
        }
    </style>
</head>
<body>
    <header>
        <h1>Student Portal</h1>
        <p>
            Welcome to the HTML5 Base Template
        </p>
    </header>
    <nav>
        <a href="#">Home</a>
        <a href="#">Courses</a>
        <a href="#">Assignments</a>
        <a href="#">Contact</a>
    </nav>
    <main>
        <h2>Dashboard</h2>
        <p>
            This is the main content area of the student portal.
        </p>
        <p>
            HTML5 semantic tags improve structure and browser compatibility.
        </p>
    </main>
    <footer>
        <p>
            © 2026 Student Portal | All Rights Reserved
        </p>
    </footer>
</body>
</html>