<!DOCTYPE html>
<html>
<head>
    <title>Video Invite</title>
    <style>
        body{
            font-family: Arial;
            text-align: center;
            padding: 20px;
        }
        video{
            border: 3px solid blue;
        }
    </style>
    <script>
        window.onbeforeunload = function(){
            return "Your form is not finished!";
        }
        function readyVideo(){
            document.getElementById("msg").innerHTML =
            "Video ready to play";
        }
    </script>
</head>
<body>
    <h2>Event Promo Video</h2>
    <video width="400"
           controls
           oncanplay="readyVideo()">
        <source src="video.mp4"
                type="video/mp4">
    </video>
    <p id="msg"></p>
</body>
</html>