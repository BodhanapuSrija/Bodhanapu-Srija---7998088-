<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Responsive Portal</title>
<style>
body{
    margin:0;
    font-family:Arial;
    background:#eef2f7;
}
header{
    background:#0056b3;
    color:white;
    text-align:center;
    padding:3vh;
}
nav{
    display:flex;
    justify-content:center;
    gap:20px;
    background:#003366;
    padding:2vh;
}
nav a{
    color:white;
    text-decoration:none;
    font-size:1.2vw;
}
.container{
    display:flex;
    justify-content:center;
    gap:3%;
    padding:4vh;
    flex-wrap:wrap;
}
.card{
    width:25%;
    background:white;
    padding:2vh;
    border-radius:10px;
    text-align:center;
    box-shadow:0 0 10px gray;
}
img{
    width:100%;
    height:30vh;
    border-radius:10px;
}
@media screen and (max-width:768px){
    nav{
        flex-direction:column;
        align-items:center;
    }
    nav a{
        font-size:18px;
    }
    .card{
        width:80%;
    }
    img{
        height:22vh;
    }
    h1{
        font-size:24px;
    }
    p{
        font-size:14px;
    }
}
</style>
</head>
<body>
<header>
<h1>
Local Community Event Portal
</h1>
</header>
<nav>
<a href="#">Home</a>
<a href="#">Events</a>
<a href="#">Gallery</a>
<a href="#">Contact</a>
</nav>
<div class="container">
<div class="card">
<img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=400">
<h2>
Music Festival
</h2>
<p>
Enjoy live music and cultural programs.
</p>
</div>
<div class="card">
<img src="https://images.unsplash.com/photo-1511578314322-379afb476865?w=400">
<h2>
Community Meetup
</h2>
<p>
Meet local people and join activities.
</p>
</div>
</div>
</body>
</html>