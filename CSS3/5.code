<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Typography Demo</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">
<style>
body{
    margin:0;
    background:#eef2f7;
    font-family:'Poppins',sans-serif;
    text-align:center;
}
header{
    background:#0056b3;
    color:white;
    padding:25px;
}
h1{
    font-size:40px;
    font-weight:600;
    letter-spacing:2px;
    text-transform:uppercase;
}
.box{
    background:white;
    width:350px;
    margin:40px auto;
    padding:20px;
    border-radius:12px;
    box-shadow:0 0 10px gray;
}
h2{
    font-size:28px;
    font-style:italic;
    color:#003366;
}
p{
    font-size:18px;
    font-weight:300;
    line-height:1.8;
    letter-spacing:1px;
    text-align:justify;
    text-transform:capitalize;
    color:#444;
}
img{
    width:100%;
    border-radius:10px;
}
</style>
</head>
<body>
<header>
<h1>
Community Portal
</h1>
</header>
<div class="box">
<img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=400">
<h2>
Music Festival
</h2>
<p>
join the exciting local music festival and enjoy live performances with your community members.
</p>
</div>
</body>
</html>