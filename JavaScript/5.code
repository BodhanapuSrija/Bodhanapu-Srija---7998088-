<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Objects & Prototypes</title>
<style>
body{
    font-family:Arial;
    background:#eef2f7;
    text-align:center;
}
.card{
    width:330px;
    margin:40px auto;
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0 0 10px gray;
}
img{
    width:100%;
    border-radius:10px;
}
p{
    text-align:left;
}
</style>
</head>
<body>
<div class="card">
<img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=400">
<h1>
Community Event
</h1>
<div id="data"></div>
</div>
<script src="main.js"></script>
</body>
</html>